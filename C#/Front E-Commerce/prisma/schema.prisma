// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model utilisateurs {
  id            Int        @id @default(autoincrement())
  prenom        String
  nom           String
  email         String     @unique
  password      String
  adresse       String
  telephone     String
}

model administrateurs {
  id            Int        @id @default(autoincrement())
  prenom        String
  nom           String
  email         String     @unique
  password      String
  adresse       String
  telephone     String
} 

model panier {
  id            Int        @id @default(autoincrement())
  produit       String
  ingredients   String[]
  prix_unitaire String
  quantite      String
  prix_total    String
  prenom        String
  nom           String
}

model commandes {
  id            Int       @id @default(autoincrement())
  produits      String[]
  prix          String
  date          String
  prenom        String
  nom           String
  adresse       String
  telephone     String
  finished      Boolean   @default(false)
}

model avis {
  id            Int       @id @default(autoincrement())
  name          String
  email         String
  commentaire   String
}